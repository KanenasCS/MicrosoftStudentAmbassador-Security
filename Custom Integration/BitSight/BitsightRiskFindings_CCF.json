                                "destinations": {
                                    "logAnalytics": [
                                        {
                                            "workspaceResourceId": "[variables('workspaceResourceId')]",
                                            "name": "clv2ws1"
                                        }
                                    ]
                                },
                                "dataFlows": [
                                    {
                                        "streams": [
                                            "Custom-BitsightRiskFindingsRaw"
                                        ],
                                        "destinations": [
                                            "clv2ws1"
                                        ],
                                        "transformKql": "source\n| extend _d = details\n| extend raw = pack('temporary_id', temporary_id, 'risk_vector', risk_vector, 'risk_category', risk_category, 'risk_vector_label', risk_vector_label, 'grade', grade, 'severity', severity, 'severity_category', severity_category, 'affects_rating', affects_rating, 'first_seen', first_seen, 'last_seen', last_seen, 'duration', duration, 'evidence_key', evidence_key, 'rolledup_observation_id', rolledup_observation_id, 'impacts_risk_vector_details', impacts_risk_vector_details, 'remaining_decay', remaining_decay, 'remediated', remediated, 'comments', comments, 'assets', assets, 'tags', tags, 'details', details)\n| extend rv = tolower(iif(isnotempty(tostring(_d.risk_vector)), tostring(_d.risk_vector), tostring(risk_vector)))\n| extend gr = tolower(iif(isnotempty(tostring(_d.grade)), tostring(_d.grade), tostring(grade)))\n| extend sev = iif(isnotnull(_d.severity), toreal(_d.severity), toreal(severity))\n| extend sevcat = tolower(iif(isnotempty(tostring(_d.severity_category)), tostring(_d.severity_category), tostring(severity_category)))\n| extend normalized_risk_state = case(gr in ('good','fair','warn','bad','neutral'), gr, sevcat in ('severe','material'), 'bad', sevcat == 'moderate', 'warn', sevcat == 'minor', 'fair', sev >= 7.0, 'bad', sev >= 4.0, 'warn', sev >= 1.0, 'fair', 'unknown')\n| where normalized_risk_state in ('warn','bad')\n| where rv in ('botnet_infections','spam_propagation','malware_servers','unsolicited_comm','potentially_exploited','ssl_certificates','patching_cadence','mobile_software','open_ports','file_sharing')\n| extend _cguid = iif(isnotempty(tostring(_d.company_guid)), tostring(_d.company_guid), '')\n| extend _evid = iif(isnotempty(tostring(_d.rolledup_observation_id)), tostring(_d.rolledup_observation_id), iif(isnotempty(tostring(_d.evidence_key)), tostring(_d.evidence_key), iif(isnotempty(tostring(temporary_id)), tostring(temporary_id), hash_sha256(tostring(raw)))))\n| project\n    TimeGenerated = now(),\n    company_guid = _cguid,\n    company_name = iif(isnotempty(tostring(_d.company_name)), tostring(_d.company_name), ''),\n    finding_uid = strcat(_cguid, ':', rv, ':', _evid),\n    temporary_id = tostring(temporary_id),\n    risk_category = iif(isnotempty(tostring(_d.risk_category)), tostring(_d.risk_category), tostring(risk_category)),\n    risk_vector = rv,\n    risk_vector_label = iif(isnotempty(tostring(_d.risk_vector_label)), tostring(_d.risk_vector_label), tostring(risk_vector_label)),\n    finding_grade = gr,\n    severity = sev,\n    severity_category = sevcat,\n    normalized_risk_state,\n    affects_rating = tobool(affects_rating),\n    first_seen = todatetime(iif(isnotempty(tostring(_d.first_seen)), tostring(_d.first_seen), tostring(first_seen))),\n    last_seen = todatetime(iif(isnotempty(tostring(_d.last_seen)), tostring(_d.last_seen), tostring(last_seen))),\n    duration = iif(isnotempty(tostring(_d.duration)), tostring(_d.duration), tostring(duration)),\n    evidence_key = iif(isnotempty(tostring(_d.evidence_key)), tostring(_d.evidence_key), tostring(evidence_key)),\n    rolledup_observation_id = iif(isnotempty(tostring(_d.rolledup_observation_id)), tostring(_d.rolledup_observation_id), tostring(rolledup_observation_id)),\n    impacts_risk_vector_details = iif(isnotempty(tostring(_d.impacts_risk_vector_details)), tostring(_d.impacts_risk_vector_details), tostring(impacts_risk_vector_details)),\n    remaining_decay = iif(isnotnull(_d.remaining_decay), toreal(_d.remaining_decay), toreal(remaining_decay)),\n    remediated = iif(isnotnull(_d.remediated), tobool(_d.remediated), tobool(remediated)),\n    comments = iif(isnotempty(tostring(_d.comments)), tostring(_d.comments), tostring(comments)),\n    assets = assets,\n    tags = iif(isnotnull(_d.tags), _d.tags, tags),\n    details = _d,\n    raw = raw",
                                        "outputStream": "Custom-BitsightRiskFindings_CL"
                                    }
                                ]
                            }
                        },
                        {
                            "name": "[variables('_logAnalyticsTableId1')]",
                            "apiVersion": "2022-10-01",
