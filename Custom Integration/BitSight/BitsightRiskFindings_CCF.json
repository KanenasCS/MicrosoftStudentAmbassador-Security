                "packageName": "[variables('_solutionName')]",
                "contentProductId": "[concat(substring(variables('_solutionId'), 0, 50),'-','dc','-', uniqueString(concat(variables('_solutionId'),'-','DataConnector','-',variables('_dataConnectorContentIdConnectorDefinition'),'-', variables('dataConnectorVersionConnectorDefinition'))))]",
                "packageId": "[variables('_solutionId')]",
                "contentSchemaVersion": "3.0.0",
                "version": "[variables('_solutionVersion')]"
            }
        },
        {
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',variables('_dataConnectorContentIdConnectorDefinition'))]",
            "apiVersion": "2022-09-01-preview",
            "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
            "location": "[parameters('workspace-location')]",
            "kind": "Customizable",
            "properties": {
                "connectorUiConfig": {
                    "id": "BitsightRiskFindingsConnectorDefinition",
                    "title": "Bitsight Risk Findings (CCF)",
                    "publisher": "Obrela",
                    "descriptionMarkdown": "Ingests Bitsight Security Ratings risk-vector findings for a portfolio company into Microsoft Sentinel using the Codeless Connector Framework. Migrated from the Bitsight Risk Vector Azure Function solution.",
                    "graphQueriesTableName": "BitsightRiskFindings_CL",
                    "graphQueries": [
                        {
                            "metricName": "Total findings received",
                            "legend": "Bitsight risk findings",
                            "baseQuery": "BitsightRiskFindings_CL"
                        }
                    ],
                    "sampleQueries": [
                        {
                            "description": "Current deduplicated bad/warn findings",
                            "query": "BitsightRiskFindings_CL\n| summarize arg_max(TimeGenerated, *) by finding_uid\n| where normalized_risk_state in ('warn','bad')\n| order by TimeGenerated desc"
                        },
                        {
                            "description": "Findings by risk vector and state",
                            "query": "BitsightRiskFindings_CL\n| summarize Findings=count() by normalized_risk_state, risk_vector_label"
                        }
                    ],
                    "dataTypes": [
                        {
                            "name": "BitsightRiskFindings_CL",
                            "lastDataReceivedQuery": "BitsightRiskFindings_CL\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
                        }
                    ],
                    "connectivityCriteria": [
                        {
                            "type": "HasDataConnectors"
                        }
                    ],
                    "availability": {
                        "isPreview": true
                    },
                    "permissions": {
                        "resourceProvider": [
                            {
                                "provider": "Microsoft.OperationalInsights/workspaces",
                                "permissionsDisplayText": "Read and Write permissions are required.",
                                "providerDisplayName": "Workspace",
                                "scope": "Workspace",
                                "requiredPermissions": {
                                    "write": true,
                                    "read": true,
                                    "delete": true
                                }
                            }
                        ],
                        "customs": [
                            {
                                "name": "Bitsight API token",
                                "description": "A Bitsight API token with access to the target portfolio company is required. Generate it from Account > API Tokens in the Bitsight console."
                            },
                            {
                                "name": "Company GUID",
                                "description": "The Bitsight company GUID whose findings will be ingested. One connection ingests one company."
                            }
                        ]
                    },
                    "instructionSteps": [
                        {
                            "title": "Connect Bitsight to Microsoft Sentinel",
                            "description": "Provide the Bitsight API token and the company GUID, then select Connect. One connection ingests findings for one company; add additional connections to cover more companies.",
                            "instructions": [
                                {
                                    "type": "Textbox",
                                    "parameters": {
                                        "label": "Company GUID",
                                        "placeholder": "00000000-0000-0000-0000-000000000000",
                                        "type": "text",
                                        "name": "companyGuid"
                                    }
                                },
                                {
                                    "type": "Textbox",
                                    "parameters": {
                                        "label": "Bitsight API token",
                                        "placeholder": "Your Bitsight API token",
                                        "type": "password",
                                        "name": "apiToken"
                                    }
                                },
                                {
                                    "type": "ConnectionToggleButton",
                                    "parameters": {
                                        "connectLabel": "Connect",
                                        "name": "connect"
                                    }
                                }
                            ]
                        }
                    ]
                }
            }
        },
        {
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',concat('DataConnector-', variables('_dataConnectorContentIdConnectorDefinition')))]",
