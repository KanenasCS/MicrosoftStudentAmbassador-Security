                                                "type": "string"
                                            },
                                            {
                                                "name": "grade",
                                                "type": "string"
                                            },
                                            {
                                                "name": "severity",
                                                "type": "real"
                                            },
                                            {
                                                "name": "severity_category",
                                                "type": "string"
                                            },
                                            {
                                                "name": "affects_rating",
                                                "type": "boolean"
                                            },
                                            {
                                                "name": "first_seen",
                                                "type": "string"
                                            },
                                            {
